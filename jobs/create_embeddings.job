#!/bin/bash
#SBATCH --job-name=embeddings
#SBATCH --partition=gpu_a100
#SBATCH --gpus=1
#SBATCH --time=2:00:00
#SBATCH --cpus-per-task=8
#SBATCH --mem=32G
#SBATCH --output=jobs/outputs/%x-%j.out
#SBATCH --error=jobs/outputs/%x-%j.err

cd $HOME/GRID

module purge
module load 2025
module load Anaconda3/2025.06-1

source $(conda info --base)/etc/profile.d/conda.sh
conda activate RecSys

python -m src.inference \
    experiment=sem_embeds_inference_flat \
    data_dir=/projects/prjs2120/groups/group_08/data/amazon_data/toys \
    hydra.run.dir=/projects/prjs2120/groups/group_08/results/embeddings/toys

